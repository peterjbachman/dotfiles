{
    "restore_source_documents": false,
    "save_workspace": "never",
    "load_workspace": false,
    "always_save_history": false,
    "restore_last_project": false,
    "soft_wrap_r_files": true,
    "continue_comments_on_newline": true,
    "highlight_selected_line": true,
    "show_invisibles": true,
    "show_indent_guides": true,
    "syntax_color_console": true,
    "scroll_past_end_of_document": true,
    "highlight_r_function_calls": true,
    "auto_append_newline": true,
    "strip_trailing_whitespace": true,
    "check_arguments_to_r_function_calls": true,
    "check_unexpected_assignment_in_function_call": true,
    "warn_if_no_such_variable_in_scope": true,
    "warn_variable_defined_but_not_used": true,
    "style_diagnostics": true,
    "editor_theme": "Kiss",
    "pdf_previewer": "system",
    "posix_terminal_shell": "zsh",
    "show_terminal_tab": false,
    "default_sweave_engine": "knitr",
    "initial_working_directory": "~",
    "graphics_backend": "quartz",
    "graphics_antialiasing": "subpixel",
    "jobs_tab_visibility": "shown",
    "panes": {
        "quadrants": [
            "Source",
            "TabSet1",
            "Console",
            "TabSet2"
        ],
        "tabSet1": [
            "History",
            "Connections",
            "Build",
            "VCS",
            "Tutorial",
            "Presentation"
        ],
        "tabSet2": [
            "Environment",
            "Files",
            "Plots",
            "Packages",
            "Help",
            "Viewer"
        ],
        "hiddenTabSet": [],
        "console_left_on_top": false,
        "console_right_on_top": true,
        "additional_source_columns": 0
    },
    "python_type": "system",
    "python_version": "3.9.1",
    "python_path": "/usr/local/bin/python3.9",
    "show_hidden_files": true,
    "check_for_updates": false,
    "rainbow_parentheses": true,
    "restore_source_document_cursor_position": false,
    "show_help_tooltip_on_idle": true,
    "limit_visible_console": true,
    "show_doc_outline_rmd": true,
    "visual_markdown_editing_wrap_at_column": 80,
    "rmd_viewer_type": "pane",
    "visual_markdown_editing_wrap": "column",
    "reduced_motion": true
}